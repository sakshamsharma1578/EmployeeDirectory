<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AddressBook</title>

    <!-- Tailwind -->
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">

    <!-- site.css -->
    <link href="~/css/site.css" rel="stylesheet" />
    <link rel="icon" type="image/png" href="~/images/logoAPP.png" />

    <!-- GSAP -->
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.2/dist/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.2/dist/ScrollTrigger.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.2/dist/ScrollSmoother.min.js"></script>

    <style>
        :root {
            --bg: #000000;
            --card: #0f1113;
            --muted: #9aa0a6;
            --gold: #d4af37;
        }

        html, body {
            margin: 0;
            padding: 0;
            background: var(--bg);
            color: #e6e6e6;
            font-family: system-ui, Arial, sans-serif;
            overflow-x: hidden;
        }

        /* ---------------- BACKGROUND VIDEO ---------------- */
        #video-bg {
            position: fixed;
            inset: 0;
            z-index: 0 !important; /* FIXED */
            pointer-events: none !important;
        }

            #video-bg video.bg-video {
                width: 100%;
                height: 100%;
                object-fit: cover;
                opacity: 0.55;
                pointer-events: none !important;
                user-select: none !important;
            }

            /* Soft overlay so video remains visible */
            #video-bg::after {
                content: "";
                position: absolute;
                inset: 0;
                background: rgba(0,0,0,0.25); /* FIXED (was 0.75 hiding video) */
            }

        /* ---------------- SELECT (dropdown) ---------------- */
        .select-wrapper {
            position: relative;
            display: inline-block;
        }

            .select-wrapper select {
                appearance: none;
                -webkit-appearance: none;
                -moz-appearance: none;
                background-color: rgba(255,255,255,0.04);
                border: 1px solid rgba(255,215,0,0.25);
                color: #e6e6e6;
                padding: 8px 36px 8px 12px;
                border-radius: 8px;
                font-size: 14px;
            }

            .select-wrapper::after {
                content: "▼";
                font-size: 12px;
                color: #d4af37;
                position: absolute;
                right: 12px;
                top: 50%;
                transform: translateY(-50%);
                pointer-events: none;
            }

        select option {
            background-color: #0f1113;
            color: #e6e6e6;
            padding: 8px;
            border: none;
        }

            select option:hover {
                background-color: #1b1f23;
                color: #d4af37;
            }

            select option:checked,
            select:focus option:checked {
                background-color: #d4af37 !important;
                color: #081017 !important;
            }

        /* ---------------- SMOOTH SCROLL ---------------- */
        #smooth-wrapper {
            position: relative;
            overflow: hidden;
        }

        #smooth-content {
            position: relative;
            width: 100%;
            z-index: 10 !important; /* FIXED so content appears above video */
        }

        /* HEADER */
        .site-header {
            position: fixed;
            top: 16px;
            left: 16px;
            z-index: 300;
            display: flex;
            gap: 12px;
            align-items: center;
            transition: backdrop-filter 0.3s ease;
        }

        .site-actions {
            position: fixed;
            top: 16px;
            right: 16px;
            z-index: 300;
        }

        /* GOLD BUTTON */
        .btn-gold {
            background: linear-gradient(90deg, var(--gold), #b59028);
            padding: .45rem 1rem;
            border-radius: 9px;
            color: #000;
            font-weight: 600;
            box-shadow: 0 0 20px rgba(212,175,55,0.18);
            transition: transform .3s ease;
        }

            .btn-gold:hover {
                transform: translateY(-3px) scale(1.05);
            }

        /* UI BOXES */
        .neumo {
            background: rgba(15,17,19,0.68);
            border-radius: 12px;
            border: 1px solid rgba(255,215,0,0.06);
            padding: 0.9rem;
            box-shadow: 0 8px 30px rgba(0,0,0,0.5);
        }

        /* CARD */
        .card {
            background: rgba(15,17,19,0.78);
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.05);
            padding: 1.25rem;
            transition: .25s ease;
        }

            .card:hover {
                transform: translateY(-8px) scale(1.01);
                box-shadow: 0 20px 50px rgba(0,0,0,0.6);
            }

        /* INPUTS */
        input, select, textarea {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.15);
            color: white;
            padding: .45rem .6rem;
            border-radius: 6px;
        }

        main {
            padding-top: 120px;
        }
    </style>
</head>

<body>

    <!-- BACKGROUND VIDEO -->
    <div id="video-bg">
        <video autoplay
               muted
               loop
               playsinline
               preload="auto"
               disablepictureinpicture
               controlslist="nodownload nofullscreen noremoteplayback"
               class="bg-video">
            <source src="/videos/hero.mp4" type="video/mp4">
        </video>
    </div>

    <!-- SMOOTH SCROLL -->
    <div id="smooth-wrapper">
        <div id="smooth-content">

            <!-- HEADER -->
            <div class="site-header" id="header">
                <a href="/" style="display:flex;align-items:center;gap:10px;color:inherit;text-decoration:none;">
                    <div style="width:56px;height:56px;border-radius:12px;background:rgba(212,175,55,0.15);display:flex;align-items:center;justify-content:center;">
                        <img src="/images/logoAPP.png" style="width:40px;height:40px;object-fit:cover;">
                    </div>
                    <div>
                        <div style="font-weight:700;">Employee Book</div>
                        <div class="muted text-sm">Employee Directory</div>
                    </div>
                </a>
            </div>

            <div class="site-actions">
                <a href="/" class="btn-gold">Home</a>
            </div>

            <!-- MAIN CONTENT -->
            <main>
                @RenderBody()
            </main>

            <footer class="text-center py-10 muted">
                © @DateTime.UtcNow.Year Employee Book — Made By Saksham Sharma
            </footer>

        </div>
    </div>

    <!-- GSAP INIT -->
    <script>
        gsap.registerPlugin(ScrollTrigger, ScrollSmoother);

        const smoother = ScrollSmoother.create({
            wrapper: "#smooth-wrapper",
            content: "#smooth-content",
            smooth: 1.1,
            effects: true
        });

        /* HEADER BLUR ON SCROLL */
        ScrollTrigger.create({
            start: 0,
            end: 400,
            onUpdate: (self) => {
                const blur = Math.min(self.progress * 10, 6);
                document.getElementById("header").style.backdropFilter =
                    `blur(${blur}px) brightness(${1 - self.progress * 0.25})`;
            }
        });

        /* CARD ANIMATIONS */
        gsap.utils.toArray(".card").forEach((card, i) => {
            gsap.from(card, {
                opacity: 0,
                y: 60,
                duration: 0.9,
                ease: "power3.out",
                delay: i * 0.05,
                scrollTrigger: {
                    trigger: card,
                    start: "top 85%"
                }
            });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
